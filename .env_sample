# .env_sample
# Copy this file to .env and replace the values with your actual configuration.
# DO NOT commit the .env file to version control.

# AlloyDB Core Configuration
ALLOYDB_CLUSTER="YOUR_CLUSTER_ID_HERE"
ALLOYDB_INSTANCE="YOUR_INSTANCE_ID_HERE"
DB_PASSWORD="YOUR_EXISTING_DB_PASSWORD"

# Google Cloud Region
REGION="us-central1"
